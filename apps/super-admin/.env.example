# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/edu_crm
# Optional dedicated control DB URL (overrides DATABASE_URL for tenant registry)
# CONTROL_DATABASE_URL=postgresql://postgres:password@localhost:5432/Shribi Edufy_control
DB_HOST=localhost
DB_PORT=5432
DB_NAME=edu_crm
DB_USER=postgres
DB_PASSWORD=your-password

# Multi-tenant control database (school registry) — required for /register-school
CONTROL_DB_HOST=localhost
CONTROL_DB_PORT=5432
CONTROL_DB_NAME=Shribi Edufy_control
CONTROL_DB_USER=postgres
CONTROL_DB_PASSWORD=your-password

# Auth
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars
JWT_SECRET=your-jwt-secret-min-32-chars
NEXTAUTH_URL=http://localhost:7000
APP_BASE_DOMAIN=localhost:7000
NEXT_PUBLIC_APP_BASE_DOMAIN=localhost:7000
NEXT_PUBLIC_APP_URL=http://localhost:7000

# 2factor.in SMS (Sprint 5 Communications)
# Get API key from https://2factor.in/
OTP_API_KEY=your-2factor-api-key-here
# 6-character DLT-approved sender ID (required for TSMS/PSMS)
SMS_SENDER_ID=EDULKH
