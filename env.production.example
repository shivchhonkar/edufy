# Production environment template — copy to apps/super-admin/.env on the server
# cp env.production.example apps/super-admin/.env

# ── PostgreSQL (required) ─────────────────────────────────────────────────────
DB_HOST=your-postgres-host
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change-me
# Or use a single URL (password extracted automatically):
# DATABASE_URL=postgresql://postgres:change-me@your-postgres-host:5432/edu_crm

# ── Control DB (tenant registry — required for /register-school) ─────────────
CONTROL_DB_HOST=your-postgres-host
CONTROL_DB_PORT=5432
CONTROL_DB_NAME=Shribi Edufy_control
CONTROL_DB_USER=postgres
CONTROL_DB_PASSWORD=change-me
# Or: CONTROL_DATABASE_URL=postgresql://postgres:change-me@host:5432/Shribi Edufy_control

# Default tenant DB name (legacy / first school if not using register-school UI)
DB_NAME=edu_crm

# ── Auth (required — use long random strings) ───────────────────────────────
JWT_SECRET=replace-with-min-32-char-secret
NEXTAUTH_SECRET=replace-with-min-32-char-secret
NEXTAUTH_URL=https://your-domain.com

# ── Multi-tenant URLs ───────────────────────────────────────────────────────
APP_BASE_DOMAIN=your-domain.com
NEXT_PUBLIC_APP_BASE_DOMAIN=your-domain.com
NEXT_PUBLIC_APP_URL=https://your-domain.com

# ── SMS (optional) ──────────────────────────────────────────────────────────
# OTP_API_KEY=
# SMS_SENDER_ID=EDULKH
